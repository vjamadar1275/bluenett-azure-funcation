{
  "version": "2.0",
  "extensions": {
        "eventHubs": {
                "maxEventBatchSize": 100,
                "prefetchCount": 300,
                "batchCheckpointFrequency": 1
        }
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}